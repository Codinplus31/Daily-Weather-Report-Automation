    {
      "parameters": {
        "jsCode": "const html = $input.first().json.data;\n\nconst tempMatch = html.match(/(\\d+)°C/);\nconst descMatch = html.match(/aria-label=\"([^\"]*weather[^\"]*)\"/)\nconst humidityMatch = html.match(/(\\d+)%/);\nconst windMatch = html.match(/(\\d+)\\s*km\\/h/);\n\nreturn [{ json: {\n  location: \"Lagos\",\n  country: \"Nigeria\",\n  current: {\n    temp: tempMatch ? tempMatch[1] + \"°C\" : \"N/A\",\n    description: descMatch ? descMatch[1] : \"N/A\",\n    humidity: humidityMatch ? humidityMatch[1] + \"%\" : \"N/A\",\n    windSpeed: windMatch ? windMatch[1] + \" km/h\" : \"N/A\"\n  }\n}}];"
      },
      "id": "00329589-6f15-4913-b4ac-f4a5daf05253",
