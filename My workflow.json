{
  "name": "My workflow",
  "nodes": [
    {
      "parameters": {
        "promptType": "define",
        "text": "=Create a fun, engaging, and personalized weather email for today based on this data:\n\n{{ JSON.stringify($json, null, 2) }}\n\nWrite an email that:\n1. Has a catchy, weather-related subject line\n2. Describes how the day will feel (temperature, conditions)\n3. Gives specific outfit recommendations\n4. Mentions any weather changes expected during the day\n5. Has a fun, upbeat tone\n6. Is formatted as HTML with proper structure\n\nReturn ONLY the HTML email content, ready to send.",
        "options": {
          "systemMessage": "You are a friendly weather assistant who writes fun, personalized daily weather emails. You take weather data and transform it into engaging content that helps people plan their day and choose appropriate clothing."
        }
      },
      "id": "83031bf1-a8f0-4e03-a9e6-580d0ffd1a56",
      "name": "Create Fun Weather Email",
      "type": "@n8n/n8n-nodes-langchain.agent",
